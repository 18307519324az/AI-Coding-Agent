# Local development defaults. Copy to `.env` only when you need overrides.

RUNNER_HOST=127.0.0.1
RUNNER_PORT=8787
RUNNER_API_URL=http://127.0.0.1:8787
NEXT_PUBLIC_RUNNER_API_URL=http://127.0.0.1:8787

# Leave blank for unauthenticated local development. Set both values together when testing auth.
RUNNER_API_KEY=
WEB_AUTH_USERNAME=admin
WEB_AUTH_PASSWORD=
WEB_AUTH_SESSION_SECRET=

OPENAI_AGENT_MODE=deterministic
OPENAI_MODEL=gpt-5.2
OPENAI_API_KEY=

GITHUB_PR_MODE=simulated
GITHUB_TOKEN=

WORKSPACE_ROOT=.workspaces
RUNNER_ARTIFACT_DIR=.runner-data/artifacts
RUNNER_STORE_FILE=.runner-data/store.json
RUNNER_EXECUTION_MODE=mock

RUNNER_JOB_MODE=inline
RUNNER_JOB_WORKER_INTERVAL_MS=1000
RUNNER_JOB_WORKER_CONCURRENCY=1
RUNNER_JOB_MAX_ATTEMPTS=3
RUNNER_JOB_RETRY_BACKOFF_MS=1000

RUNNER_WORKSPACE_RETENTION_HOURS=168
RUNNER_WORKSPACE_CLEANUP_INTERVAL_MS=3600000
RUNNER_WORKSPACE_CLEANUP=enabled
