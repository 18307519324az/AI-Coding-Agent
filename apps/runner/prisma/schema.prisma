generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id
  email     String      @unique
  name      String?
  createdAt DateTime    @default(now())
  tasks     AgentTask[]
}

model Repository {
  id            String      @id
  owner         String
  name          String
  url           String
  defaultBranch String      @default("main")
  provider      String      @default("github")
  createdAt     DateTime    @default(now())
  tasks         AgentTask[]
}

model AgentTask {
  id           String        @id
  userId       String
  repositoryId String
  title        String
  prompt       String
  issueUrl     String?
  status       String
  branchName   String?
  prUrl        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id])
  repository   Repository    @relation(fields: [repositoryId], references: [id])
  logs         AgentRunLog[]
  traces       AgentTraceEvent[]
  approvals    Approval[]
  testResults  TestResult[]
  e2eArtifacts E2eArtifact[]
  jobs         RunnerJob[]
}

model AgentRunLog {
  id        String   @id
  taskId    String
  level     String
  phase     String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  task      AgentTask @relation(fields: [taskId], references: [id])
}

model AgentTraceEvent {
  id        String   @id
  taskId    String
  type      String
  phase     String
  summary   String
  metadata  Json?
  createdAt DateTime @default(now())
  task      AgentTask @relation(fields: [taskId], references: [id])
}

model Approval {
  id         String    @id
  taskId     String
  type       String
  status     String
  payload    Json
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  task       AgentTask @relation(fields: [taskId], references: [id])
}

model TestResult {
  id         String    @id
  taskId     String
  command    String
  status     String
  output     String
  durationMs Int
  createdAt  DateTime  @default(now())
  task       AgentTask @relation(fields: [taskId], references: [id])
}

model E2eArtifact {
  id          String    @id
  taskId      String
  command     String
  reportUrl   String
  screenshots Json
  createdAt   DateTime  @default(now())
  task        AgentTask @relation(fields: [taskId], references: [id])
}

model RunnerJob {
  id          String     @id
  taskId      String?
  type        String
  status      String
  payload     Json
  attempts    Int        @default(0)
  maxAttempts Int        @default(3)
  nextRunAt   DateTime?
  error       String?
  createdAt   DateTime   @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  task        AgentTask? @relation(fields: [taskId], references: [id])
}
