generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id
  email     String      @unique
  name      String?
  createdAt DateTime    @default(now())
  tasks     AgentTask[]
}

model Repository {
  id            String      @id
  owner         String
  name          String
  url           String
  defaultBranch String      @default("main")
  provider      String      @default("github")
  createdAt     DateTime    @default(now())
  tasks         AgentTask[]
}

model AgentTask {
  id           String        @id
  userId       String
  repositoryId String
  title        String
  prompt       String
  issueUrl     String?
  status       String
  branchName   String?
  prUrl        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id])
  repository   Repository    @relation(fields: [repositoryId], references: [id])
  logs         AgentRunLog[]
  approvals    Approval[]
  testResults  TestResult[]
}

model AgentRunLog {
  id        String   @id
  taskId    String
  level     String
  phase     String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  task      AgentTask @relation(fields: [taskId], references: [id])
}

model Approval {
  id         String    @id
  taskId     String
  type       String
  status     String
  payload    Json
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  task       AgentTask @relation(fields: [taskId], references: [id])
}

model TestResult {
  id         String    @id
  taskId     String
  command    String
  status     String
  output     String
  durationMs Int
  createdAt  DateTime  @default(now())
  task       AgentTask @relation(fields: [taskId], references: [id])
}

